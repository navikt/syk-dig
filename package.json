{
    "name": "syk-dig",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "packageManager": "yarn@4.17.0",
    "engines": {
        "node": "24"
    },
    "scripts": {
        "dev": "concurrently --names 'next,gen'  --prefix-colors 'blue,magenta' 'yarn dev:next' 'yarn gen:watch'",
        "dev:next": "next dev | pino-pretty --messageKey=message",
        "start:e2e": "NEXT_PUBLIC_ASSET_PREFIX= node .next/standalone/server.js | pino-pretty --messageKey=message",
        "build": "./scripts/pre-build.sh && next build",
        "build:e2e": "./scripts/build-e2e.sh",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "test": "vitest --config vitest.config.mts",
        "e2e": "playwright test",
        "e2e:dev": "yarn e2e --ui",
        "e2e:fast": "FAST=true yarn e2e --ui",
        "gen": "graphql-codegen",
        "gen:watch": "graphql-codegen --watch",
        "pull-schema": "wget https://syk-dig-backend.intern.dev.nav.no/schema.json -O ./schema.json && oxfmt schema.json",
        "update-schema": "yarn pull-schema && yarn gen",
        "prepare": "husky"
    },
    "dependencies": {
        "@apollo/client": "^4.2.6",
        "@graphql-tools/schema": "^10.0.35",
        "@graphql-typed-document-node/core": "^3.2.0",
        "@hookform/error-message": "^2.0.1",
        "@navikt/aksel-icons": "^8.15.0",
        "@navikt/ds-css": "^8.15.0",
        "@navikt/ds-react": "^8.15.0",
        "@navikt/next-api-proxy": "^5.0.5",
        "@navikt/next-logger": "^5.0.0",
        "@navikt/oasis": "^4.1.4",
        "@navikt/tsm-diagnoser": "^2026.1.13",
        "@unleash/nextjs": "^1.6.7",
        "clsx": "^2.1.1",
        "date-fns": "^4.4.0",
        "fuse.js": "^7.4.2",
        "graphql": "^16.14.2",
        "graphql-yoga": "^5.21.2",
        "next": "16.2.10",
        "next-logger": "^5.0.2",
        "nextleton": "^0.6.1",
        "node-cache": "^5.1.2",
        "pdfobject": "^2.3.1",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "prom-client": "^15.1.3",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "react-hook-form": "^7.81.0",
        "react-resizable-panels": "^4.12.1",
        "remeda": "^2.39.0",
        "rxjs": "^7.8.2",
        "swr": "^2.4.2",
        "tailwind-merge": "^3.6.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@graphql-codegen/add": "^7.1.0",
        "@graphql-codegen/cli": "^7.2.0",
        "@graphql-codegen/fragment-matcher": "^7.1.0",
        "@graphql-codegen/typed-document-node": "^7.1.0",
        "@graphql-codegen/typescript-operations": "^6.1.0",
        "@graphql-codegen/typescript-resolvers": "^6.1.0",
        "@hookform/devtools": "^4.4.0",
        "@navikt/ds-tailwind": "^8.15.0",
        "@navikt/tsm-oxfmt": "^0.0.9",
        "@navikt/tsm-oxlint": "^0.0.4",
        "@parcel/watcher": "^2.5.6",
        "@playwright/test": "1.61.1",
        "@tailwindcss/postcss": "^4.3.2",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "24.13.2",
        "@types/pdfobject": "^2.2.5",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "^6.0.3",
        "concurrently": "^10.0.3",
        "dotenv": "^17.4.2",
        "graphql-sock": "^1.0.1",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "lint-staged": "^17.0.8",
        "next-router-mock": "^1.0.5",
        "nock": "^14.0.16",
        "oxfmt": "^0.58.0",
        "oxlint": "^1.73.0",
        "oxlint-tsgolint": "^0.24.0",
        "postcss": "^8.5.16",
        "tailwindcss": "^4.3.2",
        "typescript": "6.0.3",
        "vite": "^8.1.3",
        "vitest": "^4.1.10",
        "vitest-dom": "^0.1.1"
    }
}
